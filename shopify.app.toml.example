# Copy this into the Shopify app repo or Dev Dashboard-managed config
# and replace the placeholder client_id before releasing a new app version.

name = "Shipide"
client_id = "REPLACE_WITH_SHOPIFY_API_KEY"
application_url = "https://portal.shipide.com"
embedded = true

[access_scopes]
scopes = "read_orders,write_orders,read_locations"

[auth]
redirect_urls = ["https://portal.shipide.com/api/shopify/callback"]

[webhooks]
api_version = "2025-10"

[[webhooks.subscriptions]]
compliance_topics = ["customers/data_request", "customers/redact", "shop/redact"]
uri = "https://portal.shipide.com/api/shopify/webhooks/compliance"
